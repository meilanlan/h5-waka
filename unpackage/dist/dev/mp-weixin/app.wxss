/*每个页面公共css */
body {
  font-family: "PingFang SC-Medium", "PingFang SC";
  color: #0E1B2E;
  line-height: 1;
  background-color: #F4F5F7;
}
* {
  box-sizing: border-box;
}
.common-header {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
  width: 100%;
  min-height: 120rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
}
.common-header .back {
  width: 48rpx;
  height: 48rpx;
  position: absolute;
  left: 32rpx;
  cursor: pointer;
}
.common-header .gy {
  width: 48rpx;
  height: 48rpx;
}
.common-header text {
  font-size: 36rpx;
  font-family: "PingFang SC-Medium";
  font-weight: 500;
  color: #000000;
}
.common-header.safeTop {
  padding-top: 88rpx;
}
.robotList .list {
  margin-bottom: 24rpx;
  padding: 32rpx;
  height: 208rpx;
  background: #FFFFFF;
  box-shadow: 0px 4rpx 20rpx 1rpx rgba(197, 204, 213, 0.1);
  border-radius: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
}
.robotList .list > * {
  flex-shrink: 0;
}
.robotList .list .left {
  display: flex;
  align-items: center;
}
.robotList .list .headimg {
  width: 140rpx;
  height: 140rpx;
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
}
.robotList .list .headimg image {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
}
.robotList .list .headimg image.off {
  filter: blur(6rpx);
}
.robotList .list .headimg .off-text {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  text-align: center;
  line-height: 140rpx;
  color: #FFFFFF;
  font-size: 24rpx;
  filter: blur(0);
}
.robotList .list .info {
  margin-left: 24rpx;
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.4);
}
.robotList .list .info .name {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  display: flex;
  align-items: center;
}
.robotList .list .info .name .cv {
  width: 80rpx;
  height: 32rpx;
  margin-left: 16rpx;
}
.robotList .list .info .ing {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  font-weight: 400;
}
.robotList .list .info .ing > * {
  flex-shrink: 0;
}
.robotList .list .info .ing text {
  color: #1675FE;
  padding: 0 4rpx;
}
.robotList .list .info .ing .ing-box {
  display: flex;
  align-items: center;
  margin-right: 18rpx;
}
.robotList .list .info .ing .ing-icon {
  margin-right: 8rpx;
  width: 28rpx;
  height: 28rpx;
  vertical-align: middle;
}
.robotList .list .info .medal {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  font-weight: 400;
}
.robotList .list .info .medal image {
  width: 32rpx;
  height: 32rpx;
  margin-left: 8rpx;
}
.robotList .list .info .st {
  margin-top: 20rpx;
}
.robotList .list .info .st .st-img::before {
  content: "";
  display: inline-block;
  width: 30rpx;
  height: 30rpx;
  background-repeat: no-repeat;
  background-size: contain;
  vertical-align: middle;
}
.robotList .list .info .st .st-img::after {
  content: "";
  display: inline-block;
  font-size: 24rpx;
  margin-left: 10rpx;
}
.robotList .list .info .st .st-img.st-true::before {
  content: "";
}
.robotList .list .info .st .st-img.st-true::after {
  content: "在线";
  color: #00B386;
}
.robotList .list .info .st .st-img.st-false::before {
  content: "";
}
.robotList .list .info .st .st-img.st-false::after {
  content: "已离线";
  color: #606178;
}
.robotList .list .off-text {
  width: 297rpx;
  height: 34rpx;
  position: absolute;
  bottom: 34rpx;
  left: 323rpx;
}
.robotList .list .btn {
  padding: 0 30rpx;
  height: 56rpx;
  border-radius: 40rpx;
  border: 2rpx solid #EEF0F4;
  text-align: center;
  line-height: 56rpx;
  font-size: 24rpx;
  color: #9DA9B9;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
.robotList .list .btn image {
  display: block;
  width: 24rpx;
  height: 24rpx;
  margin-left: 4rpx;
}
 .uni-popup .uni-popup__wrapper {
  border-radius: 30rpx 30rpx 0 0;
}
.common-popup {
  width: 100vw;
  height: calc(100vh - 120px);
  padding: 40rpx 28rpx;
  background-color: #ffffff;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
}
.no-data {
  margin-top: 328rpx;
  text-align: center;
  font-size: 28rpx;
  color: #606163;
  font-weight: 400;
}
.no-data image {
  margin-bottom: 14rpx;
  width: 366rpx;
  height: 366rpx;
}
.visibility-none {
  visibility: hidden;
}
.clearSurePopup {
  width: 630rpx;
  border-radius: 30rpx;
  background-color: #ffffff;
  padding: 100rpx 30rpx 50rpx;
}
.clearSurePopup .clearText {
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 1.5;
}
.clearSurePopup .btn-box {
  margin-top: 60rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.clearSurePopup .btn-box .btn {
  width: 260rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 20rpx;
  font-size: 32rpx;
  cursor: pointer;
  background: #E5EAF1;
}
.clearSurePopup .btn-box .btn.btn-sure {
  color: #ffffff;
  background: #1675FE;
}
.common-empty {
  margin-top: 76rpx;
  text-align: center;
  font-size: 32rpx;
  color: #606178;
}
.common-empty image {
  display: block;
  margin: 0 auto 42rpx;
  width: 200rpx;
  height: 200rpx;
