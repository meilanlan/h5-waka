}
.my-lucky-btn.data-v-16a8f7e1 {
    position: absolute;
    top: 126rpx;
    left: 126rpx;
    width: 234rpx;
    height: 234rpx;
    background-color: rgba(234, 204, 255, .8);
    border-radius: 50%;
    filter: blur(5px); /* 边缘虚化效果*/
    opacity: 0;
&.active.data-v-16a8f7e1 {
      animation: btnScaleFade-16a8f7e1 1s linear 1 forwards;
}
}
@keyframes btnScaleFade-16a8f7e1 {
0% {
      transform: scale(1);
      opacity: 1;
      filter: blur(5px);
}
50%{
      opacity: 0.8;
      filter: blur(5px);
}
100% {
      transform: scale(3);
      opacity: 0;
      filter: blur(5px);
}
}
  
