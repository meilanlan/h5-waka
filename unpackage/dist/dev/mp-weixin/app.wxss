/* 三角形 */
.common-arrow {
  border-right: 3rpx solid #9DA9B9;
  border-top: 3rpx solid #9DA9B9;
  height: 18rpx;
  width: 18rpx;
  transform: rotate(45deg);
  -webkit-transform: rotate(45deg);
  /*不加这两个属性三角会比上一个略丑, 大家可以试一下*/
  border-left: 2rpx solid transparent;
  border-bottom: 2rpx solid transparent;
}
/* 向上的三角形 */
.arrow-top {
  width: 0;
  height: 0;
  border-right: 20rpx solid transparent;
  border-left: 20rpx solid transparent;
  border-bottom: 20rpx solid #ffffff;
  border-radius: 10rpx;
}
.textEllipsis { /* 超过1行文本...显示 */
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  word-break: break-all;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}
.text2Ellipsis { /* / 超过两行文本...显示 */
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  word-break: break-all;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
